PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000
JWT_SECRET=replace_this_with_a_long_random_secret

# PostgreSQL. Set DATABASE_URL to use PostgreSQL.
# Example: postgresql://postgres:password@localhost:5432/resume_builder
# Leave empty to use server/data/local-db.json for quick local demos.
DATABASE_URL=
PGSSL=false

# Optional Gemini AI key. ATS scoring and keyword matching run locally;
# this key upgrades AI enhancement, parsing, guided help, and cover letters.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional ImageKit credentials. Local uploads are used when empty.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
